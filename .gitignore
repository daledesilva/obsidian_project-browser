# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
dist/*

# Exclude sourcemaps
*.map

# obsidian
data.json

# Obsidian E2E cache
.obsidian-cache/

# Credentials for Obsidian Insiders (beta)
.env
.env.*
!.env.example

# QA test vault (generated — only generate.mjs and README.md committed)
qa-test-vault/*
!qa-test-vault/generate.mjs
!qa-test-vault/README.md

# Jest coverage (regenerated by test runs)
coverage/

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Local reference material (not part of the plugin)
/_reference_*/
